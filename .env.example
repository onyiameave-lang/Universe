# Copy to .env. Every key is OPTIONAL (honest degradation without them).

# ============================================================
# LLM Brain — Ollama (LOCAL, RECOMMENDED) or Cloud Providers
# ============================================================
# FIX-02: Ollama is now the PRIMARY LLM provider when configured.
# Ollama runs locally (no external API calls, no rate limits, no costs).
# Download models: ollama pull llama3
# Start Ollama: ollama serve (default port 11434)
# Examples: llama3, mistral, phi3, neural-chat, orca-mini
OLLAMA_MODEL=llama3
OLLAMA_URL=http://localhost:11434

# Cloud LLM providers (fallback if Ollama unavailable)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER_ORDER=ollama,anthropic,openai,gemini

# ============================================================
# Nexus Gemini-Powered Routing + RL Pipeline (FIX-CA-26)
# ============================================================
# NEXUS_GEMINI_KEY — SEPARATE key dedicated to Nexus routing decisions.
# Uses gemini-2.0-flash (fast, cheap). Different from GEMINI_API_KEY above.
# Plug in a second Gemini API key here. Get one at https://aistudio.google.com/
# When set: Nexus uses Gemini Flash to extract symbols, correct typos, and
# choose the right agent. Every decision is logged to Nexus/data/routing_decisions.jsonl
# and becomes training data for the local Ollama model (RL loop).
# When NOT set: Nexus falls back to COMPANY_ALIAS + regex extraction (always works).
NEXUS_GEMINI_KEY=

# GEMINI_API_KEY (above) is used for FINAL ANSWER SYNTHESIS (multi-agent merge).
# Ollama is tried first for synthesis; GEMINI_API_KEY is the fallback.

# RL training thresholds
NEXUS_MIN_SAMPLES=100          # Minimum logged decisions before local model is used
NEXUS_LOCAL_CONF=0.75          # Minimum local model confidence to trust it over Gemini
NEXUS_ACCURACY_THRESH=0.80     # Minimum eval accuracy to promote local model to Tier 1
NEXUS_TRAIN_MODEL=nexus-router # Name for the trained local routing model in Ollama

# --- Sentinel (news); RSS works without a key ---
NEWSAPI_KEY=

# --- Pulse (social); Reddit public JSON works without keys ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Chronicle embeddings ---
MEMORY_USE_REAL_EMBEDDINGS=false

# --- Oracle / MT5 trading (SAFE DEFAULTS) ---
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
ORACLE_PAPER_TRADING=true          # set false to trade live
ORACLE_ALLOW_LIVE=false            # extra lock for REAL-money accounts
# --- risk limits ---
RL_RISK_PER_TRADE=0.01
RL_MAX_POSITIONS=1
RL_MAX_DRAWDOWN_PCT=0.20